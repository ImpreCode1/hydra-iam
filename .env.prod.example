# =========================
# Environment variables for production
# Copy to .env.prod and fill in values
# =========================

# PostgreSQL shared credentials
POSTGRES_USER=hydra
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=hydra_iam
NOTIFICATIONS_DB=hydra_notifications

# =========================
# hydra-core
# =========================
DATABASE_URL=postgresql://hydra:your_secure_password_here@hydra-db:5432/hydra_iam

# Auth - CHANGE THESE IN PRODUCTION!
JWT_SECRET=your_very_secure_jwt_secret_here

# Azure AD OAuth - CHANGE THESE IN PRODUCTION!
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret
AZURE_REDIRECT_URI=https://your-domain.com/auth/microsoft/callback

# Cookie encryption - CHANGE THESE IN PRODUCTION!
COOKIE_ENCRYPTION_KEY=your_32_char_encryption_key_here
COOKIE_ENCRYPTION_IV=your_12_char_iv_here

# URL del frontend for redirects
FRONTEND_URL=https://your-domain.com

# Admin user email
SEED_ADMIN_EMAIL=admin@yourcompany.com

# Service to Service Auth - CHANGE THESE IN PRODUCTION!
SERVICE_JWT_SECRET=your_very_secure_service_secret
SERVICE_JWT_EXPIRES_IN=1h

# API URL
API_URL=https://your-domain.com

# =========================
# hydra-notifications
# =========================
NOTIFICATIONS_DATABASE_URL=postgresql://hydra:your_secure_password_here@hydra-notifications-db:5432/hydra_notifications